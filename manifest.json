{
  "manifest_version": 3,
  "name": "Smart Media Pause",
  "version": "3.1",
  "permissions": ["storage"],
  "host_permissions": [
    "*://www.youtube.com/*",
    "*://www.netflix.com/*",
    "*://open.spotify.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://www.youtube.com/*",
        "*://www.netflix.com/*",
        "*://open.spotify.com/*"
      ],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "./icon16.png",
    "48": "./icon48.png",
    "128": "./icon128.png"
  },
  "action": {
    "default_popup": "popup.html"
  }
}